{
  "name": "clean-commit",
  "displayName": "CleanCommit",
  "description": "AI-powered commit message generator using Conventional Commits",
  "version": "1.1.7",
  "packageManager": "pnpm@11.14.0",
  "publisher": "brandonpalmeros",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonpaldom/clean-commit.git"
  },
  "bugs": {
    "url": "https://github.com/brandonpaldom/clean-commit/issues"
  },
  "homepage": "https://github.com/brandonpaldom/clean-commit#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Machine Learning"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "conventional-commits",
    "gemini",
    "openai",
    "groq",
    "openrouter",
    "gpt",
    "llama"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cleancommit-container",
          "title": "CleanCommit",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "cleancommit-container": [
        {
          "type": "webview",
          "id": "cleancommit.sidebar",
          "name": "Commit Assistant",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "cleancommit.generateCommit",
        "title": "Generate Commit Message",
        "category": "CleanCommit"
      },
      {
        "command": "cleancommit.setApiKey",
        "title": "Set API Key",
        "category": "CleanCommit"
      },
      {
        "command": "cleancommit.resetModel",
        "title": "Restore Recommended Model",
        "category": "CleanCommit"
      }
    ],
    "configuration": {
      "title": "CleanCommit",
      "properties": {
        "cleancommit.provider": {
          "type": "string",
          "default": "gemini",
          "scope": "window",
          "enum": [
            "gemini",
            "openai",
            "groq",
            "openrouter"
          ],
          "enumDescriptions": [
            "Google Gemini (gemini-3.1-flash-lite) - Fast and cost-efficient",
            "OpenAI (gpt-5.6-luna) - Small model for cost-sensitive workloads",
            "Groq (openai/gpt-oss-20b) - Compact and ultra fast",
            "OpenRouter (google/gemini-3.1-flash-lite) - Lightweight multi-provider access"
          ],
          "enumItemLabels": [
            "Google Gemini",
            "OpenAI",
            "Groq",
            "OpenRouter"
          ],
          "markdownDescription": "AI provider used to generate commit messages. API keys are stored separately in VS Code Secret Storage."
        },
        "cleancommit.language": {
          "type": "string",
          "default": "en",
          "scope": "window",
          "enum": [
            "en",
            "es"
          ],
          "enumDescriptions": [
            "English",
            "Spanish"
          ],
          "enumItemLabels": [
            "English",
            "Spanish"
          ],
          "description": "Language used for generated commit messages."
        },
        "cleancommit.includeBody": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "Generate a detailed commit body below the Conventional Commit subject."
        },
        "cleancommit.maxDiffSize": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "maximum": 100000,
          "multipleOf": 500,
          "scope": "window",
          "markdownDescription": "Maximum number of staged diff characters sent to the selected AI provider. Larger diffs are truncated. Higher values can increase latency and API cost."
        },
        "cleancommit.confirmBeforeCommit": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "Ask for confirmation before creating a Git commit from the sidebar."
        },
        "cleancommit.geminiModel": {
          "type": "string",
          "default": "gemini-3.1-flash-lite",
          "minLength": 1,
          "scope": "window",
          "markdownDescription": "Gemini model ID. Recommended: `gemini-3.1-flash-lite`. Run **CleanCommit: Restore Recommended Model** to reset it."
        },
        "cleancommit.openaiModel": {
          "type": "string",
          "default": "gpt-5.6-luna",
          "minLength": 1,
          "scope": "window",
          "markdownDescription": "OpenAI model ID. Recommended: `gpt-5.6-luna`. Run **CleanCommit: Restore Recommended Model** to reset it."
        },
        "cleancommit.groqModel": {
          "type": "string",
          "default": "openai/gpt-oss-20b",
          "minLength": 1,
          "scope": "window",
          "markdownDescription": "Groq model ID. Recommended: `openai/gpt-oss-20b`. Run **CleanCommit: Restore Recommended Model** to reset it."
        },
        "cleancommit.openrouterModel": {
          "type": "string",
          "default": "google/gemini-3.1-flash-lite",
          "minLength": 1,
          "scope": "window",
          "markdownDescription": "OpenRouter model slug. Recommended: `google/gemini-3.1-flash-lite`. Run **CleanCommit: Restore Recommended Model** to reset it."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "publish:ovsx": "ovsx publish --pat $OVSX_PAT",
    "publish:all": "pnpm run publish:ovsx && vsce publish",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "groq-sdk": "^0.8.0",
    "lucide": "^0.575.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
