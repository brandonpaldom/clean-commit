{
  "name": "clean-commit",
  "displayName": "CleanCommit",
  "description": "AI-powered commit message generator using Conventional Commits",
  "version": "1.1.5",
  "packageManager": "pnpm@11.14.0",
  "publisher": "brandonpalmeros",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonpaldom/clean-commit.git"
  },
  "bugs": {
    "url": "https://github.com/brandonpaldom/clean-commit/issues"
  },
  "homepage": "https://github.com/brandonpaldom/clean-commit#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Machine Learning"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "conventional-commits",
    "gemini",
    "openai",
    "groq",
    "openrouter",
    "gpt",
    "llama"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cleancommit-container",
          "title": "CleanCommit",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "cleancommit-container": [
        {
          "type": "webview",
          "id": "cleancommit.sidebar",
          "name": "Commit Assistant",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "cleancommit.generateCommit",
        "title": "Generate Commit Message",
        "category": "CleanCommit"
      },
      {
        "command": "cleancommit.setApiKey",
        "title": "Set API Key",
        "category": "CleanCommit"
      }
    ],
    "configuration": {
      "title": "CleanCommit",
      "properties": {
        "cleancommit.provider": {
          "type": "string",
          "default": "gemini",
          "enum": [
            "gemini",
            "openai",
            "groq",
            "openrouter"
          ],
          "enumDescriptions": [
            "Google Gemini (gemini-3.1-flash-lite) - Fast and cost-efficient",
            "OpenAI (gpt-5.6-luna) - Small model for cost-sensitive workloads",
            "Groq (openai/gpt-oss-20b) - Compact and ultra fast",
            "OpenRouter (google/gemini-3.1-flash-lite) - Lightweight multi-provider access"
          ],
          "description": "AI provider for commit message generation"
        },
        "cleancommit.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "es"
          ],
          "enumDescriptions": [
            "English",
            "Spanish"
          ],
          "description": "Language for generated commit messages"
        },
        "cleancommit.includeBody": {
          "type": "boolean",
          "default": false,
          "description": "Include detailed body in commit message"
        },
        "cleancommit.maxDiffSize": {
          "type": "number",
          "default": 4000,
          "description": "Maximum diff size in characters to send to AI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "publish:ovsx": "ovsx publish --pat $OVSX_PAT",
    "publish:all": "pnpm run publish:ovsx && vsce publish",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "groq-sdk": "^0.8.0",
    "lucide": "^0.575.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
