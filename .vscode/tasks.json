{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch",
            "dependsOn": [
                "pnpm: watch:tsc",
                "pnpm: watch:esbuild"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "label": "pnpm: watch:esbuild",
            "type": "shell",
            "command": "pnpm",
            "args": ["run", "watch:esbuild"],
            "isBackground": true,
            "problemMatcher": {
                "owner": "typescript",
                "source": "esbuild",
                "applyTo": "allDocuments",
                "fileLocation": "absolute",
                "pattern": [
                    {
                        "regexp": "^✘ \\[ERROR\\] (.*)$",
                        "message": 1
                    },
                    {
                        "regexp": "^    (.*):(\\d+):(\\d+):$",
                        "file": 1,
                        "line": 2,
                        "column": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\[watch\\] build started$",
                    "endsPattern": "^\\[watch\\] build finished$"
                }
            },
            "presentation": {
                "group": "watch",
                "reveal": "never"
            }
        },
        {
            "label": "pnpm: watch:tsc",
            "type": "shell",
            "command": "pnpm",
            "args": ["run", "watch:tsc"],
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "presentation": {
                "group": "watch",
                "reveal": "never"
            }
        },
        {
            "label": "pnpm: watch-tests",
            "type": "shell",
            "command": "pnpm",
            "args": ["run", "watch-tests"],
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "presentation": {
                "group": "watchers",
                "reveal": "never"
            }
        },
        {
            "label": "tests: watch",
            "dependsOn": [
                "watch",
                "pnpm: watch-tests"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}
